{
  "name": "leetcode",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": ["--name", "leetcode"],
  "workspaceFolder": "/workspaces/leetcode",
  "mounts": [
    "source=leetcode-node-modules,target=/workspaces/leetcode/node_modules,type=volume",
    "source=/run/host-services/ssh-auth.sock,target=/ssh-agent,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "customizations": {
    "vscode": {
      "extensions": ["biomejs.biome", "eamodio.gitlens"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          "source.organizeImports.biome": "explicit"
        }
      }
    }
  },
  "postCreateCommand": "yarn install"
}
